# World Sim — Environment
# NEVER commit this file to version control.

# Provider mode: mock, nim-dry-run, nim-live
WORLD_PROVIDER_MODE=mock
WORLD_TICK_INTERVAL=5000
WORLD_MAX_TICKS=0
WORLD_SAVE_INTERVAL=10

# Default agents
WORLD_AGENTS=Adam,Eve

# Adam
AGENT_ADAM_ROLE=first human, gardener, builder
AGENT_ADAM_PROVIDER=mock
AGENT_ADAM_MODEL=meta/llama-3.1-8b-instruct
AGENT_ADAM_NIM_KEY=

# Eve
AGENT_EVE_ROLE=companion, explorer, relational intelligence
AGENT_EVE_PROVIDER=mock
AGENT_EVE_MODEL=meta/llama-3.1-8b-instruct
AGENT_EVE_NIM_KEY=

# Add new agents:
# AGENT_<NAME>_ROLE=
# AGENT_<NAME>_PROVIDER=mock|nim-dry-run|nim-live
# AGENT_<NAME>_MODEL=
# AGENT_<NAME>_NIM_KEY=
