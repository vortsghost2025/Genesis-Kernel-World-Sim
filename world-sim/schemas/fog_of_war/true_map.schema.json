    "world_id": {"type": "string"},
    "seed": {"type": "string"},
    "continents": {"type": "array", "items": {"type": "object"}},
    "regions": {"type": "array", "items": {"type": "object"}},
    "tiles": {"type": "array", "items": {"type": "object"}},
    "landmarks": {"type": "array", "items": {"type": "object"}},
    "resources": {"type": "array", "items": {"type": "object"}},
    "hazards": {"type": "array", "items": {"type": "object"}},
    "mysteries": {"type": "array", "items": {"type": "object"}},
    "travel_edges": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": false
}
